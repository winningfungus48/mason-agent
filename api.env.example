# Copy these lines into /home/mason/agent/.env on the droplet (merge with existing secrets).
# Do not commit real values.
#
# Google Calendar + Tasks — token.json is written on the server (gitignored).
#
# Path A (recommended): Dashboard → "Connect Google" (browser OAuth).
#   1) In Google Cloud Console create an OAuth client type "Web application".
#   2) Authorized redirect URI (must match exactly): https://YOUR_PUBLIC_API/auth/google/callback
#   3) Download JSON → save as /home/mason/agent/credentials_web.json (or set GOOGLE_OAUTH_CLIENT_SECRETS).
#   4) Set GOOGLE_OAUTH_REDIRECT_URI to that same callback URL.
#   5) Optional: DASHBOARD_GOOGLE_SUCCESS_REDIRECT=https://YOURUSER.github.io/mason-agent/?google_connected=1
#
# Legacy: credentials.json (Desktop) + scripts/google_reauth*.py — still supported for token.json only.

# --- Mason API (dashboard) auth ---
# openssl rand -hex 32
SESSION_SECRET=

# Password for the web dashboard (server-side only)
DASHBOARD_PASSWORD=

# Browser origins allowed to call the API (comma-separated, no spaces required).
# Must include your GitHub Pages origin exactly, e.g. https://YOURUSER.github.io
# (required for GitHub Pages + ngrok; restart mason-api after changing).
DASHBOARD_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,https://YOURUSER.github.io

# Optional: long random string for curl / monitoring (X-API-Key header)
# DASHBOARD_API_KEY=

# Optional: token lifetime in seconds (default 14 days)
# DASHBOARD_TOKEN_MAX_AGE=1209600
